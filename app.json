{
  "expo": {
    "name": "Lotus Business",
    "slug": "lotus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/lotus.png",
    "scheme": "lotus",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.litxx.lotusbusiness",
      "versionCode": 1,
      "navigationBar": { "backgroundColor": "#FFFFFF" } ,
      "adaptiveIcon": {
        "foregroundImage": "./assets/lotus.png",
        "backgroundColor": "#FFFFFF"
      },
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.CAMERA"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.litxx.lotusbusiness",
      "infoPlist": {
        "UIStatusBarStyle": "UIStatusBarStyleDarkContent",
        "NSCameraUsageDescription": "Utilisé pour scanner les codes-barres des produits.",
        "NSPhotoLibraryUsageDescription": "Utilisé pour ajouter des photos aux produits.",
        "NSBluetoothAlwaysUsageDescription": "Utilisé pour connecter l'imprimante Bluetooth.",
        "NSBluetoothPeripheralUsageDescription": "Utilisé pour connecter l'imprimante Bluetooth.",
        "NSLocationWhenInUseUsageDescription": "Requis pour la découverte des périphériques Bluetooth."
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-web-browser",
      [
        "expo-audio",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-navigation-bar",
        {
          "hidden": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#0A0A0A",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Lotus Business"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "android": {
            "image": "./assets/lotus.png",
            "imageWidth": 50,
            "adaptiveIcon": {
              "foregroundImage": "./assets/lotus.png",
              "backgroundColor": "#FFFFFF"
            }
          }
        }
      ],
      "expo-asset",
      "expo-media-library",
      "expo-sharing",
      "expo-font",
      "expo-image",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "41b34465-652d-4dac-802d-25b4438417f8"
      }
    }
  }
}
